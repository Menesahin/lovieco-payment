generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── NextAuth.js v5 Required Models ───

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts Account[]
  sessions Session[]

  sentRequests     PaymentRequest[] @relation("SentRequests")
  receivedRequests PaymentRequest[] @relation("ReceivedRequests")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── Application Models ───

enum RequestStatus {
  PENDING
  PAID
  DECLINED
  CANCELLED
  EXPIRED
}

model PaymentRequest {
  id             String        @id @default(cuid())
  amountCents    Int
  note           String?
  status         RequestStatus @default(PENDING)
  shareableToken String        @unique @default(cuid())

  senderId String
  sender   User   @relation("SentRequests", fields: [senderId], references: [id])

  recipientId    String?
  recipient      User?  @relation("ReceivedRequests", fields: [recipientId], references: [id])
  recipientEmail String

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  expiresAt   DateTime
  paidAt      DateTime?
  declinedAt  DateTime?
  cancelledAt DateTime?

  @@index([senderId, status])
  @@index([recipientId, status])
  @@index([recipientEmail])
  @@index([status, expiresAt])
}
